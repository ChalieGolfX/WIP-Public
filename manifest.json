{
  "name": "KS En2No",
  "description": "Change language in KS from English to Norwegian",
  "version": "0.70",
  "author": "Charlie Golf",
  "manifest_version": 3,

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png" },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": ["storage" , "nativeMessaging" , "notifications" , "tabs"],

  "action": {
    "default_popup": "popup.html"
  }
}
